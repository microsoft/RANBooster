diff --git a/fhi_lib/lib/src/xran_mod_compression.cpp b/fhi_lib/lib/src/xran_mod_compression.cpp
index c313beb..714bedb 100644
--- a/fhi_lib/lib/src/xran_mod_compression.cpp
+++ b/fhi_lib/lib/src/xran_mod_compression.cpp
@@ -21,6 +21,37 @@
 #include "xran_compression.h"
 #include "xran_fh_o_du.h"
 
+#ifdef __GNUC__
+/*
+ * Fallback implementation for 16-bit element-wise division on a 512-bit vector.
+ * AVX-512 does not provide a native integer divide intrinsic for 16-bit lanes,
+ * so use a scalar element-wise divide via a local buffer. This keeps existing
+ * call sites (which reference `_mm512_div_epi16`) unchanged.
+ */
+static inline __m512i _mm512_div_epi16(const __m512i src, const __m512i divisor)
+{
+    /* buffers must hold 32 int16_t elements (32 * 2 = 64 bytes) */
+    int16_t src_buf[32] __attribute__((aligned(64)));
+    int16_t div_buf[32] __attribute__((aligned(64)));
+    int16_t out_buf[32] __attribute__((aligned(64)));
+
+    /* store registers to memory */
+    _mm512_storeu_si512((void*)src_buf, src);
+    _mm512_storeu_si512((void*)div_buf, divisor);
+
+    /* divisor is expected to be set1 across lanes; read element 0 */
+    const int16_t unit = div_buf[0];
+
+    /* simple scalar per-element division (truncates toward zero like C integer division) */
+    for (int i = 0; i < 32; ++i)
+        out_buf[i] = src_buf[i] / unit;
+
+    /* load result back to register and return */
+    return _mm512_loadu_si512((const void*)out_buf);
+}
+
+#endif
+
 #ifdef C_Module_Used
 void
 mod_compression_qpsk_c(int16_t *pData,int8_t *pOut,int16_t unit, int32_t nSc)
