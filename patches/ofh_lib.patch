                                                  0x0000000F0000000F, 0x0000000F0000000F,
                                                  0x0000000F0000000F, 0x0000000F0000000F,
                                                  0x0000000C00000008, 0x0000000400000000);
-    return _mm512_permutevar_epi32 (k_dwordmask,comp_data_packed2);
+    return _mm512_permutexvar_epi32 (k_dwordmask,comp_data_packed2);
 }
 
